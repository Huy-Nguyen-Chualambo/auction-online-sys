<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uet.auction.controller.AdminView">
    <children>
        <VBox layoutX="14.0" layoutY="14.0" prefHeight="470.0" prefWidth="770.0" spacing="10.0">
            <children>
                <Label text="Admin Dashboard - Pending Approvals">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <TableView fx:id="tablePending" prefHeight="250.0" prefWidth="770.0">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="colName" prefWidth="200.0" text="Name" />
                        <TableColumn fx:id="colPrice" prefWidth="150.0" text="Starting Price" />
                        <TableColumn fx:id="colOwner" prefWidth="150.0" text="Seller" />
                    </columns>
                </TableView>
                <HBox spacing="20.0">
                    <children>
                        <VBox spacing="10.0">
                            <children>
                                <Label text="Set Auction Time:">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <GridPane vgap="5.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Start Date:" />
                                        <DatePicker fx:id="datePickerStart" GridPane.columnIndex="1" />
                                        <Label text="End Date:" GridPane.rowIndex="1" />
                                        <DatePicker fx:id="datePickerEnd" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                    </children>
                                </GridPane>
                                <Button mnemonicParsing="false" onAction="#handleApprove" prefHeight="40.0" prefWidth="250.0" text="APPROVE &amp; START" style="-fx-background-color: green; -fx-text-fill: white;" />
                            </children>
                        </VBox>
                        <Separator orientation="VERTICAL" />
                        <VBox spacing="10.0" prefWidth="300.0">
                            <children>
                                <Label text="Reject Product:">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <Label text="Reason:" />
                                <TextField fx:id="txtReason" promptText="Enter rejection reason" />
                                <Button mnemonicParsing="false" onAction="#handleReject" prefHeight="40.0" prefWidth="300.0" text="REJECT" style="-fx-background-color: red; -fx-text-fill: white;" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
