<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.uet.auction.controller.SellerView">
    <children>
        <VBox layoutX="150.0" layoutY="50.0" prefHeight="300.0" prefWidth="300.0" spacing="15.0">
            <children>
                <Label text="Post New Product">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <GridPane vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Product ID:" />
                        <TextField fx:id="txtId" GridPane.columnIndex="1" />
                        <Label text="Name:" GridPane.rowIndex="1" />
                        <TextField fx:id="txtName" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label text="Starting Price:" GridPane.rowIndex="2" />
                        <TextField fx:id="txtPrice" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    </children>
                </GridPane>
                <Button mnemonicParsing="false" onAction="#handlePostAction" prefHeight="40.0" prefWidth="300.0" text="Submit for Approval" />
                <Label text="Status: Product will be reviewed by Admin before going LIVE." textFill="#666666" wrapText="true" />
            </children>
        </VBox>
    </children>
</AnchorPane>
